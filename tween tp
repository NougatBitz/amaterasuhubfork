for i,v in pairs(game.Workspace.ExampleFolder:GetChildren()) do
        if v:FindFirstChild("HumanoidRootPart") then
local distance = (game.Players.LocalPlayer.Character.HumanoidRootPart.Position - v:FindFirstChild("HumanoidRootPart").Position).magnitude
tweenService, tweenInfo = game:GetService("TweenService"), TweenInfo.new((distance/NumberOfSpeedHere), Enum.EasingStyle.Linear)

